# SQLite databases — too large for GitHub, regenerated on deploy by
# scripts/build_db.py from the seed file plus the generation pipeline.
data/*.db
data/*.db.bak*

# SQLite transient files — regenerated automatically when the DB is opened
*.db-wal
*.db-shm
*.db-journal

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual envs
.venv/
venv/
env/

# Claude Code internal state
.claude/scheduled_tasks.lock

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
