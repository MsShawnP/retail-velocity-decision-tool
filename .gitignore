# SQLite databases — too large for GitHub, regenerated by setup.sh
# from the cinderhaven-data submodule.
data/*.db
data/*.db.bak*

# SQLite transient files — regenerated automatically when the DB is opened
*.db-wal
*.db-shm
*.db-journal

# Python bytecode
__pycache__/
*.py[cod]
*.pyo
.pytest_cache/

# Virtual envs
.venv/
venv/
env/

# Claude Code internal state
.claude/scheduled_tasks.lock
.claude/worktrees/

# Environment
.env

# Security - secret leak prevention
.env.*
*.pem
*.key
credentials.*
secrets.*

# OS / editor noise
.DS_Store
Thumbs.db
*.swp
.vscode/
.idea/
